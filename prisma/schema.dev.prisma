// SQLite schema used for LOCAL development only.
// Production deployment uses prisma/schema.prisma (PostgreSQL/Supabase).
// Models are kept identical so application code works against either.
//
// Notes on SQLite differences:
//  - No @db.Decimal: stored as TEXT/REAL; precision is fine for personal data
//  - No @db.Date: DateTime stored as ISO string; Prisma handles the boundary

generator client {
  provider = "prisma-client-js"
  // Library engine on SQLite — in-process, no IPC overhead.
  // The native-crash problem only affected the Postgres pooler combo.
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id           String          @id @default(cuid())
  userId       String          @default("owner")
  kind         Kind
  name         String
  icon         String
  color        String
  sortOrder    Int             @default(0)
  isArchived   Boolean         @default(false)
  createdAt    DateTime        @default(now())
  transactions Transaction[]
  templates    QuickTemplate[]

  @@unique([userId, kind, name])
  @@index([userId, kind, isArchived])
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String   @default("owner")
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  kind       Kind
  amount     Decimal
  note       String?
  occurredOn DateTime
  createdAt  DateTime @default(now())

  @@index([userId, occurredOn])
  @@index([categoryId])
}

model QuickTemplate {
  id         String   @id @default(cuid())
  userId     String   @default("owner")
  kind       Kind
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  amount     Decimal
  label      String
  sortOrder  Int      @default(0)

  @@index([userId, kind])
}

model Habit {
  id         String     @id @default(cuid())
  userId     String     @default("owner")
  name       String
  icon       String
  color      String
  sortOrder  Int        @default(0)
  isArchived Boolean    @default(false)
  createdAt  DateTime   @default(now())
  logs       HabitLog[]

  @@unique([userId, name])
  @@index([userId, isArchived])
}

model HabitLog {
  id      String   @id @default(cuid())
  userId  String   @default("owner")
  habitId String
  habit   Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  day     DateTime

  @@unique([habitId, day])
  @@index([userId, day])
}

model WorkDay {
  id          String   @id @default(cuid())
  userId      String   @default("owner")
  day         DateTime
  hours       Decimal
  description String?

  @@unique([userId, day])
  @@index([userId, day])
}

model SleepEntry {
  id      String   @id @default(cuid())
  userId  String   @default("owner")
  startAt DateTime
  endAt   DateTime

  @@index([userId, startAt])
}

model Run {
  id          String   @id @default(cuid())
  userId      String   @default("owner")
  occurredOn  DateTime
  distanceKm  Decimal
  durationSec Int
  note        String?

  @@index([userId, occurredOn])
}

model Deposit {
  id         String            @id @default(cuid())
  userId     String            @default("owner")
  name       String
  icon       String
  color      String
  goal       Decimal?
  sortOrder  Int               @default(0)
  isArchived Boolean           @default(false)
  createdAt  DateTime          @default(now())
  transfers  DepositTransfer[]

  @@unique([userId, name])
  @@index([userId, isArchived])
}

model DepositTransfer {
  id         String   @id @default(cuid())
  userId     String   @default("owner")
  depositId  String
  deposit    Deposit  @relation(fields: [depositId], references: [id], onDelete: Cascade)
  amount     Decimal
  note       String?
  occurredOn DateTime
  createdAt  DateTime @default(now())

  @@index([userId, depositId])
  @@index([depositId, occurredOn])
}

enum Kind {
  income
  expense
}
